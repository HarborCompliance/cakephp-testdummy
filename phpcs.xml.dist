<?xml version="1.0"?>
<ruleset name="TestDummy">
    <description>Coding standard for cakephp-testdummy.</description>

    <!-- Style is enforced on the test suite (the code this task adds). The
         src/ files are intentionally left as-is to avoid production-code changes;
         they are covered for correctness by phpstan instead. -->
    <file>tests</file>

    <!-- Generated migration files follow their own conventions. -->
    <exclude-pattern>tests/test_app/config/Migrations/*</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="nps"/>

    <rule ref="CakePHP"/>
</ruleset>
