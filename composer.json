{
    "name": "viraj/cakephp-testdummy",
    "description": "Factories for CakePHP tests",
    "keywords": [
        "testing",
        "cakephp",
        "testdummy",
        "stubs"
    ],
    "require": {
        "php": ">=8.2",
        "fakerphp/faker": "^1.23",
        "symfony/finder": "^6.0 || ^7.0",
        "cakephp/cakephp": "^5.3",
        "cakephp/chronos": "^3.0",
        "cakephp/migrations": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.1 || ^11.1",
        "cakephp/cakephp-codesniffer": "^5.0",
        "phpstan/phpstan": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "TestDummy\\": "src"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "TestDummy\\Test\\": "tests"
        }
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Viraj Khatavkar",
            "email": "viraj.2438@gmail.com"
        }
    ],
    "scripts": {
        "test": "phpunit",
        "cs-check": "phpcs --colors -p",
        "cs-fix": "phpcbf --colors -p",
        "stan": "phpstan analyse",
        "check": [
            "@cs-check",
            "@stan",
            "@test"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
